# Dodo — Environment Configuration
# Copy this file to .env and edit the values for your deployment.

# -----------------------------------------------------------------------------
# Django Core
# -----------------------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-to-a-long-random-string-at-least-50-characters
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,me.undp.org

# CSRF trusted origins (comma-separated)
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DB_ENGINE=postgres
DB_NAME=dodo
DB_USER=dodo
DB_PASSWORD=dodo_secure_2026
DB_HOST=db
DB_PORT=5432

# -----------------------------------------------------------------------------
# Redis (cache + Celery broker)
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# Celery
# -----------------------------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# -----------------------------------------------------------------------------
# Email (SMTP — configure for production)
# -----------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.office365.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=me-platform@undp.org
EMAIL_HOST_PASSWORD=your-smtp-password
DEFAULT_FROM_EMAIL=Dodo <noreply@undp.org>

# -----------------------------------------------------------------------------
# Container startup flags
# -----------------------------------------------------------------------------
# 1 = run migrations on container start (default), 0 = skip
RUN_MIGRATIONS=1
# 1 = collect static files on container start (default), 0 = skip
COLLECT_STATIC=1
# 1 = load demo data (setup_demo + setup_workflow) on first boot
LOAD_DEMO_DATA=1

# -----------------------------------------------------------------------------
# Exposed ports (host-side)
# -----------------------------------------------------------------------------
HTTP_PORT=80
WEB_PORT_EXPOSED=8000
DB_PORT_EXPOSED=5432
REDIS_PORT_EXPOSED=6379
